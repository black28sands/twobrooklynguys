---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const episodes = await getCollection('episodes');
  return episodes.map((ep) => ({
    params: { slug: ep.id.replace(/\.md$/, '') },
    props: { episode: ep },
  }));
}) satisfies GetStaticPaths;

const { episode } = Astro.props;
const { Content } = await episode.render();
const { data } = episode;
const epNum = String(data.episode).padStart(2, '0');
---

<BaseLayout title={`EP${epNum}: ${data.title}`} description={data.description}>
  <article>
    <!-- Episode header -->
    <header style="margin-bottom:40px;">
      <p style="color:var(--accent);font-size:0.9rem;margin-bottom:8px;">Episode {epNum}</p>
      <h1 style="font-size:2.2rem;margin-bottom:12px;">{data.title}</h1>
      <p style="color:var(--text-muted);font-size:0.9rem;">
        {data.date} &middot; {data.duration}
      </p>
      {data.tags && (
        <div style="margin-top:12px;">
          {data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Audio Player -->
    <div class="audio-player" style="margin-bottom:32px;">
      <audio id="ep-audio" controls style="width:100%;">
        <source src={data.audioUrl} type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
    </div>

    <!-- Video Player (YouTube embed or self-hosted) -->
    {data.youtubeId && (
      <div class="video-embed" style="margin-bottom:32px;">
        <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:var(--radius);">
          <div id="yt-player" data-video-id={data.youtubeId}
            style="position:absolute;top:0;left:0;width:100%;height:100%;"></div>
        </div>
      </div>
    )}
    {!data.youtubeId && data.videoUrl && (
      <div style="margin-bottom:32px;">
        <video controls style="width:100%;border-radius:var(--radius);" poster="">
          <source src={data.videoUrl} type="video/mp4" />
        </video>
      </div>
    )}

    <!-- Chapters -->
    {data.chapters && data.chapters.length > 0 && (
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:32px;">
        <h2 style="font-size:1.1rem;margin-bottom:12px;">Chapters</h2>
        {data.chapters.map((ch: { title: string; start: string }) => (
          <button class="chapter-btn" data-time={ch.start} style="display:flex;gap:12px;padding:8px 0;border:none;border-bottom:1px solid var(--border);background:none;width:100%;text-align:left;cursor:pointer;">
            <span style="color:var(--accent);font-family:monospace;min-width:50px;">{ch.start}</span>
            <span style="color:var(--text);">{ch.title}</span>
          </button>
        ))}
      </div>
    )}

    <!-- Show Notes (rendered Markdown) -->
    <div class="prose" style="line-height:1.8;">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .prose :global(h2) {
    font-size: 1.4rem;
    margin-top: 40px;
    margin-bottom: 16px;
    color: var(--text);
  }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin-top: 28px;
    margin-bottom: 12px;
  }
  .prose :global(p) {
    margin-bottom: 16px;
    color: var(--text-muted);
  }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
    color: var(--text-muted);
  }
  .prose :global(li) {
    margin-bottom: 6px;
  }
  .prose :global(a) {
    color: var(--accent);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    margin: 20px 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .chapter-btn:hover {
    background: rgba(255,255,255,0.05) !important;
  }
</style>

<script>
  // YouTube IFrame API setup
  let ytPlayer: any = null;
  const ytEl = document.getElementById('yt-player');

  if (ytEl) {
    const videoId = ytEl.getAttribute('data-video-id');
    // Load YouTube IFrame API
    const tag = document.createElement('script');
    tag.src = 'https://www.youtube.com/iframe_api';
    document.head.appendChild(tag);

    (window as any).onYouTubeIframeAPIReady = () => {
      ytPlayer = new (window as any).YT.Player('yt-player', {
        videoId: videoId,
        playerVars: { rel: 0, modestbranding: 1 },
      });
    };
  }

  // Chapter click — seek both audio and video
  document.querySelectorAll('.chapter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const time = btn.getAttribute('data-time');
      if (!time) return;
      const parts = time.split(':').map(Number);
      const seconds = parts[0] * 60 + parts[1];

      // Seek audio
      const audio = document.getElementById('ep-audio') as HTMLAudioElement;
      if (audio) {
        audio.currentTime = seconds;
        audio.play();
      }

      // Seek YouTube video
      if (ytPlayer && ytPlayer.seekTo) {
        ytPlayer.seekTo(seconds, true);
        ytPlayer.playVideo();
      }
    });
  });
</script>
